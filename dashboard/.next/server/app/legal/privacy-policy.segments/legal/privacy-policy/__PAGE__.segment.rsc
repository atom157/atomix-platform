3:["$","section",null,{"children":[["$","h2",null,{"className":"text-2xl font-bold text-white mb-4","children":"4. Third-Party Payment Processing & Subscriptions"}],["$","p",null,{"className":"leading-relaxed mb-4","children":["All payments and subscriptions for AtomiX PRO are processed securely by our authorized third-party payment provider, ",["$","strong",null,{"children":"Lava.top"}],". We do not collect, process, or store your credit card information or primary billing details on our servers. When you upgrade, you are redirected to Lava.top's secure checkout. Lava.top notifies our dashboard via a secure webhook only to confirm your payment success so we can grant you PRO access."]}],["$","p",null,{"className":"leading-relaxed","children":[["$","strong",null,{"children":"Subscription Cancellation:"}]," You may manage, pause, or cancel your PRO subscription at any time. Because billing is handled externally, all subscription management MUST be performed directly through your Lava.top billing portal: ",["$","a",null,{"href":"https://app.lava.top/my-purchases","target":"_blank","rel":"noopener noreferrer","className":"text-purple-400 hover:text-purple-300 transition-colors","children":"https://app.lava.top/my-purchases"}],"."]}]]}]
4:["$","section",null,{"children":[["$","h2",null,{"className":"text-2xl font-bold text-white mb-4","children":"5. Refund Policy"}],["$","p",null,{"className":"leading-relaxed","children":["AtomiX operates a robust Free tier that provides a generous allocation of replies allowing users to fully test the AI's capabilities prior to purchase. As such, ",["$","strong",null,{"children":"refunds are generally not issued"}],". However, we do honor a 14-day refund window strictly under the condition that the user has consumed fewer than twenty (20) AI generations since the time of their PRO upgrade."]}]]}]
